# CUKS production environment (docs/08-deployment.md, docs/runbook-install.md, task 7.1).
#
# Copy to `.env` at the repo root, fill every CHANGE_ME, then chmod 600 .env.
# This single file feeds BOTH:
#   • docker compose ${...} interpolation (CUKS_DOMAIN, POSTGRES_PASSWORD, S3_*, LIVEKIT_API_SECRET, …)
#   • the api/worker containers (env_file: ../../.env)
# so it must be passed to compose explicitly, from the repo root:
#   docker compose --env-file .env -f infra/docker/compose.prod.yaml <cmd>
#
# Hostnames use the compose service names (postgres, redis, minio, livekit, …) — the app talks to them
# over the internal docker network; only Caddy and the LiveKit media ports face the outside.
# Generate secrets with: openssl rand -base64 48   (SESSION_SECRET/ENCRYPTION_KEY: min 32 chars).

# ============================================================================
# Deployment identity (compose interpolation — Caddy, GeoServer, presigned URLs)
# ============================================================================
# Public domain the platform is served on (no scheme). Caddy gets a Let's Encrypt cert for it and for
# s3.<domain>. Point both A/AAAA records at this host before first boot.
CUKS_DOMAIN=cuks.example
# Fully-closed network without public DNS/ACME? Set this to `tls internal` (Caddy issues its own CA —
# install its root cert, printed by `docker compose ... exec caddy caddy trust`, on every workstation).
# Leave EMPTY for a real public domain (automatic Let's Encrypt).
CUKS_TLS_INTERNAL=

# ============================================================================
# Runtime
# ============================================================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
# Full public origin, scheme included — must equal https://<CUKS_DOMAIN> (env files don't interpolate).
APP_ORIGIN=https://cuks.example
TZ=Asia/Dushanbe
# Behind Caddy the real client IP arrives in X-Forwarded-For over exactly one proxy hop.
TRUST_PROXY=1

# ============================================================================
# PostgreSQL + PostGIS
# ============================================================================
# Compose provisions the DB from these (postgres service). Keep POSTGRES_* and DATABASE_URL in sync.
POSTGRES_USER=cuks
POSTGRES_DB=cuks
# URL-safe only — this value is embedded in DATABASE_URL (and Martin's) below. Generate with
# `openssl rand -hex 24`, NOT base64: a `/` from base64 breaks URL parsing and the DB connection fails.
POSTGRES_PASSWORD=CHANGE_ME_PG_PASSWORD
# App connection string — host is the compose service `postgres`; password MUST match POSTGRES_PASSWORD.
DATABASE_URL=postgres://cuks:CHANGE_ME_PG_PASSWORD@postgres:5432/cuks

# ============================================================================
# Redis (sessions, cache, BullMQ, Socket.IO adapter)
# ============================================================================
REDIS_URL=redis://redis:6379

# ============================================================================
# Sessions & encryption (required in production — see apps/api/src/config/env.ts)
# ============================================================================
SESSION_SECRET=CHANGE_ME_openssl_rand_base64_48
# Dedicated AES-256-GCM key for field encryption (TOTP secrets), decoupled from SESSION_SECRET. Min 32.
ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_48
# One-time password for the seeded `admin` account (forced change on first login).
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_bootstrap_password

# ============================================================================
# Login lockout (anti-bruteforce) — production defaults are strict; leave unset unless tuning.
# ============================================================================
# AUTH_LOCKOUT_MAX_ATTEMPTS=5
# AUTH_LOCKOUT_WINDOW_SECONDS=900

# ============================================================================
# Object storage (MinIO / S3)
# ============================================================================
# MinIO root credentials — also the S3 access/secret the api, worker and egress use.
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_REGION=us-east-1
S3_BUCKET=cuks
# Internal endpoint the api/worker use for every real S3 operation (upload, delete, retention sweep).
S3_ENDPOINT=http://minio:9000
# Browser-facing endpoint used ONLY to presign download/upload/stream URLs. Caddy proxies this subdomain
# to MinIO preserving the Host header, so SigV4 verifies. Must equal https://s3.<CUKS_DOMAIN>.
S3_PUBLIC_ENDPOINT=https://s3.cuks.example

# ============================================================================
# Email (corporate SMTP relay)
# ============================================================================
SMTP_URL=smtp://mail-relay.internal:25

# ============================================================================
# ClamAV (worker av-scan job)
# ============================================================================
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ============================================================================
# LiveKit (calls / conferences / recordings — phase 6)
# ============================================================================
# Browser-facing signaling URL. Caddy proxies /livekit -> livekit:7880 (wss), so use the public domain.
LIVEKIT_URL=wss://cuks.example/livekit
# Internal SFU URL for the api's server-side RPCs (host moderation, egress start/stop) — skips Caddy.
LIVEKIT_INTERNAL_URL=http://livekit:7880
# Key NAME is `cuks` (matches livekit.prod.yaml webhook.api_key + egress api_key). Do not change without
# updating those. The SECRET is injected into LiveKit/egress via compose interpolation of this value.
LIVEKIT_API_KEY=cuks
LIVEKIT_API_SECRET=CHANGE_ME_openssl_rand_base64_48

# ============================================================================
# GIS: GeoServer + Martin (phase 2)
# ============================================================================
# GeoServer admin (compose sets the admin password from GEOSERVER_ADMIN_PASSWORD; PROXY_BASE_URL from CUKS_DOMAIN).
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=CHANGE_ME_geoserver_admin_password
# The api publishes layers to GeoServer over the internal network.
GEOSERVER_URL=http://geoserver:8080/geoserver
GEOSERVER_WORKSPACE=cuks
# GeoServer's datastore reaches PostGIS as a read-only role (create it per docs/09 §Права PG).
GEOSERVER_PG_HOST=postgres
GEOSERVER_PG_PORT=5432
GEOSERVER_PG_USER=gis_reader
GEOSERVER_PG_PASSWORD=CHANGE_ME_gis_reader_password
# PostGIS connection shown to GIS specialists (QGIS direct). Use the VPN/LAN address clients actually
# reach; expose 5432 only to that allowlist (see compose.prod.yaml postgres note).
GIS_PG_PUBLIC_HOST=CHANGE_ME_vpn_or_lan_host
GIS_PG_PUBLIC_PORT=5432
GIS_PG_PUBLIC_DATABASE=cuks
# Vector basemap/tiles via Martin (internal).
MARTIN_URL=http://martin:3000

# ============================================================================
# Digital signatures: internal CA (docs/09-security.md §4)
# ============================================================================
# The encrypted ECDSA P-384 root key lives on the ca_data volume (mounted at /data/ca in the api).
CA_DATA_DIR=/data/ca
# Passphrase encrypting the CA key at rest — required (min 16 chars) in production.
CA_PASSPHRASE=CHANGE_ME_ca_passphrase_min_16_chars
