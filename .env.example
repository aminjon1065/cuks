# CUKS environment — exhaustive list (docs/03 §Env, docs/01 §Configuration).
# Copy to `.env` and adjust. Values below match infra/docker/compose.dev.yaml.
# Variables validated at boot live in apps/api/src/config/env.ts.

# --- Runtime ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_ORIGIN=http://localhost:5173
TZ=Asia/Dushanbe
# Proxy trust for client IP (X-Forwarded-For). Unset = trust none (dev, direct).
# In production behind Caddy set the number of proxy hops (e.g. 1) or a subnet.
TRUST_PROXY=

# --- PostgreSQL + PostGIS ---
DATABASE_URL=postgres://cuks:cuks@localhost:5432/cuks

# --- Redis (sessions, cache, BullMQ, Socket.IO adapter) ---
REDIS_URL=redis://localhost:6379

# --- Sessions (server-side sessions in Redis) ---
# Generate a strong value, e.g. `openssl rand -base64 48`. Min 32 chars.
SESSION_SECRET=dev-only-session-secret-change-me-min-32-chars

# Temporary password for the seeded `admin` account (must_change_password=true).
SEED_ADMIN_PASSWORD=ChangeMe!Now12345

# AES-256-GCM key for field encryption (TOTP secrets). Optional in dev (derived
# from SESSION_SECRET); set a dedicated random value in production.
ENCRYPTION_KEY=

# Login lockout (anti-bruteforce, docs/05 §1). Defaults = strict production
# values (5 attempts / 15 min, counted per user AND per IP). For local testing
# you can loosen or disable it — 0 disables the lockout entirely (not allowed in
# production). Uncomment to override:
# AUTH_LOCKOUT_MAX_ATTEMPTS=0
# AUTH_LOCKOUT_WINDOW_SECONDS=900

# --- Object storage (MinIO / S3) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=cuks
S3_SECRET_KEY=cuks-dev-secret
S3_REGION=us-east-1
S3_BUCKET=cuks

# --- Email (Nodemailer -> maildev in dev; corporate SMTP in prod) ---
SMTP_URL=smtp://localhost:1025

# --- ClamAV (worker av-scan job, docs/09 §2) ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- LiveKit (phase 6) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- GIS: GeoServer + Martin (phase 2) ---
GEOSERVER_URL=
GEOSERVER_ADMIN_PASSWORD=
MARTIN_URL=

# --- Digital signatures: internal CA (phase 3) ---
CA_KEY_PATH=
