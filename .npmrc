# pnpm configuration
# Strict node_modules: no phantom dependencies (ADR-15).
node-linker=isolated
# Hoist nothing implicitly; internal packages resolved via workspace protocol.
auto-install-peers=true
# Keep the store inside the repo-adjacent default; deterministic installs.
strict-peer-dependencies=false
# Allow only the pinned package manager (corepack).
package-manager-strict=false
